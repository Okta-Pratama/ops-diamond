{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/index.js"
    },
    {
      "src": "/static/(.*)",
      "dest": "/client/build/static/$1"
    },
    {
      "src": "/(manifest\\.json|favicon\\.ico|logo.*\\.png|robots\\.txt)",
      "dest": "/client/build/$1"
    },
    {
      "src": "/(.*\\.js)",
      "dest": "/client/build/$1"
    },
    {
      "src": "/(.*\\.css)",
      "dest": "/client/build/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.js"
    }
  ]
}
